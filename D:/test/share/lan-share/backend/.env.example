# ============================================
# LAN Share - 环境变量配置示例
# 复制此文件为 .env 并修改对应值
# ============================================

# ===== 环境模式 =====
# True = 开发模式（开启Swagger文档）
# False = 生产模式
DEBUG=true

# development / production
ENV=development


# ===== 服务器 =====
HOST=0.0.0.0
PORT=8000


# ===== 数据库 =====
# SQLite（轻量，零配置，推荐）
DATABASE_URL=sqlite:///../data/lanshare.db

# PostgreSQL（多用户量大时使用）
# DATABASE_URL=postgresql://username:password@localhost:5432/lanshare


# ===== 文件存储 =====
# 上传模式：文件存储在此目录（绝对路径或相对于backend/的路径）
UPLOAD_DIR=./storage/files

# 分片临时目录
CHUNK_DIR=./storage/chunks

# 索引模式：允许读取的本地路径（Windows用\\，Linux用/，逗号分隔）
INDEX_ALLOWED_PATHS=C:\\,D:\\,E:\\,F:\\,/mnt/,/home/

# 单文件大小限制（字节），0 = 无限制
# 示例：100MB = 104857600
# 示例：1GB = 1073741824
MAX_FILE_SIZE=0


# ===== JWT 认证 ⚠️ 务必修改！ =====
# 生产环境请使用随机字符串，可通过以下命令生成：
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=请在这里填写你的随机密钥，至少32位字符

# Token算法
ALGORITHM=HS256

# Token有效期（分钟），默认24小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440


# ===== 用户存储配额 =====
# 默认每个用户50GB（字节）
# 示例：50GB = 53687091200
DEFAULT_STORAGE_QUOTA=53687091200


# ===== 分片上传 =====
# 每个分片大小（字节），默认5MB
# 示例：5MB = 5242880
CHUNK_SIZE=5242880
